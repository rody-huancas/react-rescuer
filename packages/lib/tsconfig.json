{
  "compilerOptions": {
    "target"                    : "ES2020",
    "lib"                       : ["ES2020", "DOM"],
    "module"                    : "ESNext",
    "moduleResolution"          : "bundler",
    "jsx"                       : "react-jsx",
    "strict"                    : true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess"  : true,
    "declaration"               : true,
    "declarationMap"            : true,
    "skipLibCheck"              : true,
    "types"                     : ["vitest/globals"]
  },
  "include": ["src"]
}
